{
  "source": {
    "include": ["./src"],
    "includePattern": ".+\\.js$",
    "exclude": ["node_modules"]
  },
  "opts": {
    "destination": "./docs/api",
    "recurse": true,
    "readme": "../README.md",
    "template": "node_modules/docdash",
    "encoding": "utf8"
  },
  "plugins": ["plugins/markdown"],
  "tags": {
    "allowUnknownTags": true
  }
}
